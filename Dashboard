<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DuckClips Dashboard</title>

<style>
body { margin:0; font-family:Arial; background:#0f172a; color:#e2e8f0; display:flex; }

.sidebar {
  width:220px;
  background:#1e293b;
  height:100vh;
  padding:20px;
}

.sidebar h2 { text-align:center; }

.sidebar a {
  display:block;
  padding:10px;
  margin:10px 0;
  color:#e2e8f0;
  text-decoration:none;
  border-radius:8px;
}

.sidebar a:hover { background:#334155; }

.main {
  flex:1;
  padding:20px;
}

.card {
  background:#1e293b;
  padding:20px;
  margin-bottom:20px;
  border-radius:12px;
}

input, textarea {
  width:100%;
  padding:10px;
  margin-top:10px;
  border:none;
  border-radius:6px;
}

button {
  margin-top:10px;
  padding:10px 15px;
  border:none;
  border-radius:8px;
  background:#38bdf8;
  font-weight:bold;
  cursor:pointer;
}

</style>
</head>

<body>

<div class="sidebar">
  <h2>🦆 DuckClips</h2>
  <a href="#upload">Upload Clip</a>
  <a href="#manage">Manage Clips</a>
  <a href="#stats">Stats</a>
</div>

<div class="main">

  <div id="upload" class="card">
    <h2>🎬 Upload Clip</h2>
    <input type="text" placeholder="Clip Title">
    <textarea placeholder="Clip URL (YouTube, etc)"></textarea>
    <button>Post Clip</button>
  </div>

  <div id="manage" class="card">
    <h2>📂 Your Clips</h2>
    <p>No clips yet...</p>
  </div>

  <div id="stats" class="card">
    <h2>📊 Stats</h2>
    <p>Views: 0</p>
    <p>Likes: 0</p>
  </div>

</div>

</body>
</html>
